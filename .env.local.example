# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Suporte exibido no dashboard (Olá, ...) ===
# E-mail e telefone de contato da sua agência. Opcional — se vazio, usa o e-mail
# padrão e omite o telefone.
NEXT_PUBLIC_SUPPORT_EMAIL=contato@suaagencia.com.br
NEXT_PUBLIC_SUPPORT_PHONE=(11) 99999-9999

# === E-mail (Resend) ===
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@smhub.com.br

# === Assinatura digital de contratos ===
# Use uma string longa e aleatória em produção. Serve para HMAC do hash de assinatura.
CONTRACT_HASH_SECRET=

# === IA opcional (Google Gemini) para sugestão de pautas ===
GEMINI_API_KEY=

# === Mercado Pago (assinatura recorrente da plataforma) ===
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
NEXT_PUBLIC_MP_PUBLIC_KEY=

# === Trial grátis (período de teste para novas agências) ===
# Quantidade de dias de trial grátis concedidos a novas agências.
NEXT_PUBLIC_TRIAL_DIAS=7
# Limite de clientes por agência durante o trial.
NEXT_PUBLIC_TRIAL_MAX_CLIENTES=10

# === Meta Graph API (Instagram + Facebook insights p/ relatórios) ===
# Criar um app em https://developers.facebook.com (tipo Business) com os produtos
# Instagram Graph API + Facebook Login. Em produção, submeter os scopes a App Review.
META_APP_ID=
META_APP_SECRET=
# URI de redirect válida no painel da Meta: <NEXT_PUBLIC_APP_URL>/auth/meta/callback
# Chave de criptografia AES-256-GCM para tokens OAuth em repouso.
# Gere com: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=
